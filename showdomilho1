    "É formado apenas por rocha intacta",
    "Não sofre influência do clima"
  ], a:0, meta:"Solo vivo"}
];

/* =========================
   Seleção das 15 questões por partida
========================= */
function pickGameQuestions(){
  // embaralha as 100 e pega 15
  return shuffle(QBANK).slice(0, TOTAL_Q).map(q => ({
    ...q,
    // cópia defensiva das opções
    options: [...q.options]
  }));
}

/* =========================
   Elementos
========================= */
const startScreen = document.getElementById('startScreen');
const startForm = document.getElementById('startForm');
const playerNameInput = document.getElementById('playerName');
const startNoName = document.getElementById('startNoName');

const qEl = document.getElementById('question');
const qMetaEl = document.getElementById('qmeta');
const aWrap = document.getElementById('answers');
const qPos = document.getElementById('qpos');
const payoutEl = document.getElementById('payout');
const tfill = document.getElementById('tfill');
const tclock = document.getElementById('tclock');

const playerTag = document.getElementById('playerTag');
const playerNameTag = document.getElementById('playerNameTag');

const btn50 = document.getElementById('fifty');
const btnSkip = document.getElementById('skip');
const btnAsk = document.getElementById('ask');
const btnRestart = document.getElementById('restart');

/* =========================
   Estado
========================= */
function initState(){
  state = {
    qIndex: 0,
    prizeIndex: -1,
    lastSafe: -1,
    used:{ fifty:false, skip:false, ask:false },
    finished:false,
    gameQuestions: pickGameQuestions(),
    current:null
  };
  stopTimer(true);
  tRemain = TIME_PER_Q;
}

/* =========================
   Render / Sorteio de alternativas por questão
========================= */
function renderQuestion(){
  state.current = state.gameQuestions[state.qIndex];

  // embaralha alternativas mantendo resposta correta
  const zipped = state.current.options.map((text, idx) => ({ text, isCorrect: idx === state.current.a }));
  const mixed = shuffle(zipped);

  // atualiza o índice correto após shuffle
  const correctIndex = mixed.findIndex(x => x.isCorrect);
  state.current._mixed = mixed;
  state.current._correctIndex = correctIndex;

  qEl.textContent = state.current.q;
  qMetaEl.textContent = state.current.meta || "";

  aWrap.innerHTML = '';
  const labels = ['A','B','C','D'];
  mixed.forEach((opt,idx)=>{
    const btn = document.createElement('button');
    btn.type = "button";
    btn.innerHTML = `<span class="badge">${labels[idx]}</span> <span>${opt.text}</span>`;
    btn.addEventListener('click', ()=>selectAnswer(idx, btn));
    aWrap.appendChild(btn);
  });

  qPos.textContent = `Pergunta ${state.qIndex+1}/${TOTAL_Q}`;

  resetTimer();
  startTimer();
}

function selectAnswer(idx, btn){
  if(state.finished) return;
  stopTimer();

  const buttons = Array.from(aWrap.querySelectorAll('button'));
  buttons.forEach(b=>b.disabled = true);

  const isCorrect = idx === state.current._correctIndex;

  if(isCorrect){
    btn.classList.add('correct');
    state.qIndex++;
    state.prizeIndex++;
    payoutEl.textContent = fmtMilhos(PRIZES[Math.max(0, state.prizeIndex)] || 0);
    if(SAFE_STOPS.includes(state.qIndex)) state.lastSafe = state.prizeIndex;

    setTimeout(()=>{
      if(state.qIndex >= TOTAL_Q){
        endGame(true);
      }else{
        renderQuestion();
      }
    }, 800);
  } else {
    btn.classList.add('wrong');
    const correctBtn = buttons[state.current._correctIndex];
    if(correctBtn) correctBtn.classList.add('correct');
    setTimeout(()=>endGame(false), 900);
  }
}

function endGame(won){
  state.finished = true;
  aWrap.querySelectorAll('button').forEach(b=>b.disabled = true);
  stopTimer();

  const earned = won ? PRIZES[PRIZES.length-1] : (state.lastSafe>=0 ? PRIZES[state.lastSafe] : 0);
  const who = playerName ? `\nParticipante: ${playerName}` : "";

  if(won){
    qEl.textContent = `Parabéns. Você venceu o Show do Milhão.\n${who}\nPrêmio final: 1.000.000 milhos`;
    qMetaEl.textContent = "";
    payoutEl.textContent = "1.000.000 milhos";
  }else{
    qEl.textContent = `Fim de jogo. Você leva: ${fmtMilhos(earned)}\n${who}\nTente novamente para alcançar o milhão.`;
    qMetaEl.textContent = "";
  }
}

/* =========================
   Timer
========================= */
function resetTimer(){
  tRemain = TIME_PER_Q;
  updateTimerUI(1, Math.ceil(tRemain/1000));
}
function startTimer(){
  if(isTiming) return;
  isTiming = true;
  tStart = performance.now();
  const tick = (now) => {
    if(!isTiming) return;
    const elapsed = now - tStart;
    const left = Math.max(0, tRemain - elapsed);
    const pct = left / TIME_PER_Q;
    updateTimerUI(pct, Math.ceil(left/1000));
    if(left <= 0){
      stopTimer();
      timeOutLose();
    }else{
      tTick = requestAnimationFrame(tick);
    }
  };
  tTick = requestAnimationFrame(tick);
}
function stopTimer(reset=false){
  if(tTick) cancelAnimationFrame(tTick);
  if(isTiming){
    const now = performance.now();
    const elapsed = now - tStart;
    tRemain = Math.max(0, tRemain - elapsed);
  }
  isTiming = false;
  if(reset){ tRemain = TIME_PER_Q; updateTimerUI(1, Math.ceil(tRemain/1000)); }
}
function updateTimerUI(pct, secs){
  tfill.style.width = `${Math.max(0,Math.min(1,pct))*100}%`;
  tclock.textContent = `${secs}s`;
  if(secs <= 5){
    tfill.style.background = `linear-gradient(90deg, var(--danger), #ff9d5b)`;
  }else{
    tfill.style.background = `linear-gradient(90deg, var(--accent), var(--accent-2))`;
  }
}
function timeOutLose(){
  const buttons = Array.from(aWrap.querySelectorAll('button'));
  buttons.forEach(b=>b.disabled = true);
  const correctBtn = buttons[state.current._correctIndex];
  if(correctBtn) correctBtn.classList.add('correct');
  setTimeout(()=>endGame(false), 800);
}

/* =========================
   Ajudas
========================= */
btn50.addEventListener('click', ()=>{
  if(state.used.fifty || !state.current || state.finished) return;
  state.used.fifty = true;
  btn50.disabled = true;
  btn50.setAttribute('aria-disabled','true');
  const buttons = Array.from(aWrap.querySelectorAll('button'));
  const wrongIdx = [0,1,2,3].filter(i=>i!==state.current._correctIndex);
  shuffle(wrongIdx).slice(0,2).forEach(i=>{
    buttons[i].disabled = true;
    buttons[i].style.opacity = .5;
  });
});

btnSkip.addEventListener('click', ()=>{
  if(state.used.skip || !state.current || state.finished) return;
  state.used.skip = true;
  btnSkip.disabled = true;
  btnSkip.setAttribute('aria-disabled','true');
  stopTimer(true);
  // conta como avanço sem prêmio (igual à sua lógica original)
  state.qIndex++;
  if(state.qIndex >= TOTAL_Q) endGame(true);
  else renderQuestion();
});

btnAsk.addEventListener('click', ()=>{
  if(state.used.ask || !state.current || state.finished) return;
  state.used.ask = true;
  btnAsk.disabled = true;
  btnAsk.setAttribute('aria-disabled','true');

  // "especialista" (tendencioso ao correto)
  const correct = state.current._correctIndex;
  const base = [0,0,0,0];
  let remaining = 100;
  const correctPct = 45 + Math.floor(Math.random()*26);
  base[correct] = correctPct; remaining -= correctPct;
  const others = shuffle([0,1,2,3].filter(i=>i!==correct));
  base[others[0]] = Math.floor(remaining * (30+Math.random()*20)/100);
  remaining -= base[others[0]];
  base[others[1]] = Math.floor(remaining * (50+Math.random()*30)/100);
  remaining -= base[others[1]];
  base[others[2]] = remaining;

  // Mostra dica textual simples no meta (sem gráfico)
  const labels = ['A','B','C','D'];
  const ranked = base.map((v,i)=>({v,i})).sort((a,b)=>b.v-a.v);
  qMetaEl.textContent = `Especialista sugere: ${labels[ranked[0].i]} (${ranked[0].v}%), depois ${labels[ranked[1].i]} (${ranked[1].v}%).`;
});

/* =========================
   Início / Reiniciar
========================= */
btnRestart.addEventListener('click', ()=>{
  startGame();
});

startForm.addEventListener('submit', (e)=>{
  e.preventDefault();
  const name = (playerNameInput.value || "").trim();
  setPlayerName(name);
  hideStartScreen();
  startGame();
});

startNoName.addEventListener('click', ()=>{
  setPlayerName("");
  hideStartScreen();
  startGame();
});

function setPlayerName(name){
  playerName = name.slice(0, 24);
  if(playerName){
    playerNameTag.textContent = playerName;
    playerTag.style.display = "inline";
  }else{
    playerNameTag.textContent = "";
    playerTag.style.display = "none";
  }
}

function hideStartScreen(){
  startScreen.style.display = "none";
}

function startGame(){
  initState();
  payoutEl.textContent = "0 milhos";
  [btn50, btnSkip, btnAsk].forEach(b=>{
    b.disabled=false;
    b.setAttribute('aria-disabled','false');
  });
  qEl.textContent = "Carregando…";
  qMetaEl.textContent = "";
  aWrap.innerHTML = "";
  renderQuestion();
}

/* Foco no input */
setTimeout(()=>playerNameInput.focus(), 50);
</script>

</body>
</html>
