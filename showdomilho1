<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>O Show do Milhão - O Solo (100 questões + sorteio)</title>

<style>
:root{
  --bg:#0b1020;
  --panel:#121939;
  --ink:#eaf0ff;
  --muted:#a9b3d5;
  --accent:#00e1ff;
  --accent-2:#8b5cf6;
  --danger:#ff5b5b;
  --success:#22c55e;
  --gold:#f9c846;

  --ansRed1:#b31818;
  --ansRed2:#7f0f0f;
  --ansShadow:rgba(0,0,0,.45);
  --ansText:#fff3e0;
}

*{ box-sizing:border-box }
html, body { height: 100%; }

body{
  margin:0;
  font-family: Inter, system-ui, Segoe UI, Roboto, Arial, Helvetica, sans-serif;
  color:var(--ink);
  background:
    radial-gradient(1200px 600px at 10% -10%, #1c2560 0%, #0b1020 55%),
    radial-gradient(1200px 800px at 120% 120%, #2a1040 0%, #0b1020 60%);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-start;
  min-height:100%;
  padding:16px;
}

/* ===== Caixa principal ===== */
.app{
  width:min(1100px, 100%);
  background:rgba(18,25,57,0.85);
  border:2px solid var(--accent);
  border-radius:20px;
  padding:20px;
  box-shadow:0 10px 30px rgba(0,0,0,.4);
  display:flex;
  flex-direction:column;
  gap:14px;
  position:relative;
}

/* ===== Cabeçalho ===== */
header{
  background:linear-gradient(90deg, rgba(0,225,255,.15), transparent 30%, rgba(139,92,246,.15) 70%, transparent);
  border:1px solid rgba(255,255,255,.1);
  border-radius:14px;
  padding:18px;
  display:flex;
  flex-direction:column;
  gap:6px;
}
header .logo{
  font-weight:900;
  font-size:clamp(18px,2.4vw,20px);
  display:flex;
  align-items:center;
  gap:10px
}
header .logo .medal{font-size:22px; color:var(--gold)}
header .sub{color:var(--muted); font-size:13px}

/* ===== Placar abaixo do cabeçalho ===== */
.scoreboard{
  background:#0f1533;
  border:1px solid rgba(255,255,255,.1);
  border-radius:14px;
  padding:10px 12px;
  font-weight:900;
  color:var(--gold);
  text-align:center;
  font-size:16px;
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:12px;
  flex-wrap:wrap;
}
.scoreboard #payout{ display:inline-block; min-width:12ch; text-align:right; }

.playerTag{
  color:#dbe7ff;
  font-weight:800;
  font-size:14px;
  opacity:.95;
}

#restart{
  background:#111a44;
  color:var(--ink);
  border:1px solid rgba(255,255,255,.12);
  padding:8px 10px;
  border-radius:10px;
  font-weight:900;
  cursor:pointer;
}
#restart:hover{filter:brightness(1.05)}

/* ===== Layout principal ===== */
.layout{
  display:grid;
  grid-template-columns: 1.2fr .8fr;
  gap:14px;
}
@media (max-width: 880px){
  .layout{grid-template-columns:1fr;}
}

/* ===== Cartões ===== */
.card{
  background:var(--panel);
  border:1px solid rgba(255,255,255,.1);
  border-radius:16px;
  box-shadow:0 6px 20px rgba(0,0,0,.35);
}

/* ===== Área de jogo ===== */
.play{padding:18px}
.status{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:8px;
  margin-bottom:10px;
}

/* ===== Timer ===== */
.timer{
  width:100%;
  background:#0f1533;
  border:1px solid rgba(255,255,255,.1);
  border-radius:999px;
  overflow:hidden;
  height:14px;
  position:relative;
}
.timer .fill{
  height:100%;
  width:100%;
  background:linear-gradient(90deg, var(--accent), var(--accent-2));
  transition: width .1s linear;
}
.timer .clock{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:11px;
  color:#cfe3ff;
  font-weight:800;
  text-shadow:0 1px 0 rgba(0,0,0,.6);
}

/* ===== Botões de ajuda ===== */
.lifelines{display:flex; gap:8px; flex-wrap:wrap}
.lifelines button{
  background:#0f1533; color:var(--ink);
  border:1px solid rgba(255,255,255,.1);
  padding:10px 12px;
  border-radius:12px;
  cursor:pointer;
  font-weight:600;
  font-size:14px;
  display:flex;
  align-items:center;
  gap:8px;
  transition:.2s transform, .2s background;
}
.lifelines button:hover{transform:translateY(-1px); background:#111a44}
.lifelines button:disabled{opacity:.45; cursor:not-allowed; transform:none}

/* ===== Pergunta ===== */
.question{
  background:linear-gradient(180deg,#0f1a4d,#0c1333);
  border:1px solid rgba(255,255,255,.1);
  border-radius:14px;
  padding:16px;
  font-size:clamp(16px, 2.2vw, 20px);
  font-weight:700;
  line-height:1.35;
  white-space:pre-wrap;
}
.meta{
  margin-top:10px;
  color:var(--muted);
  font-size:12px;
  font-weight:700;
}

/* ===== Alternativas ===== */
.answers{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap:12px;
  margin-top:14px;
}
@media (max-width:560px){
  .answers{grid-template-columns:1fr}
}
.answers button{
  position:relative;
  text-align:left;
  padding:14px 16px;
  padding-left:62px;
  border-radius:12px;
  background:linear-gradient(180deg, var(--ansRed1), var(--ansRed2));
  color:var(--ansText);
  border:2px solid rgba(255,179,92,.75);
  box-shadow: 0 10px 18px var(--ansShadow), inset 0 1px 0 rgba(255,255,255,.18);
  cursor:pointer;
  font-size:clamp(14px, 2vw, 15px);
  font-weight:800;
  letter-spacing:.01em;
  display:flex;
  gap:12px;
  align-items:center;
  transition: transform .12s ease, filter .12s ease, box-shadow .12s ease;
  min-height:56px;
}
.answers button::before{
  content:"";
  position:absolute;
  inset:6px;
  border-radius:10px;
  border:1px solid rgba(255,255,255,.12);
  pointer-events:none;
}
.answers button .badge{
  position:absolute;
  left:12px;
  top:50%;
  transform:translateY(-50%);
  width:38px;
  height:30px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(180deg, rgba(25,40,120,.95), rgba(10,18,70,.95));
  border:2px solid rgba(255,179,92,.85);
  border-radius:8px;
  color:#eaf0ff;
  font-weight:900;
  font-size:14px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.15);
}
.answers button:hover{
  transform:translateY(-1px);
  filter:brightness(1.05);
  box-shadow: 0 12px 22px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.18);
}
.answers button.correct{
  background:linear-gradient(180deg, rgba(20,120,60,.95), rgba(8,70,35,.95));
  border-color:rgba(249,200,70,.9);
}
.answers button.wrong{
  background:linear-gradient(180deg, rgba(160,20,20,.95), rgba(90,8,8,.95));
  border-color:rgba(255,91,91,.9);
}
.answers button:disabled{opacity:.95; cursor:not-allowed}
.answers button.correct::after{ content:" ✓"; font-weight:900; margin-left:6px; }
.answers button.wrong::after{ content:" ✕"; font-weight:900; margin-left:6px; }

/* ===== Entrevistador (opcional) ===== */
.host{
  padding:14px;
  display:flex;
  flex-direction:column;
  gap:10px;
  min-height:0;
}
.hostFrame{
  width:100%;
  border-radius:14px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.12);
  background:#0f1533;
  box-shadow:0 10px 24px rgba(0,0,0,.45);
  height: clamp(260px, 55vh, 560px);
  display:flex;
  align-items:center;
  justify-content:center;
  padding:10px;
}
.hostFrame .placeholder{
  text-align:center;
  color:#b3c2ff;
  font-weight:900;
  line-height:1.35;
}
.hostCaption{
  text-align:center;
  color:#b3c2ff;
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:.12em;
  opacity:.95;
}

/* ===== Tela inicial ===== */
.startScreen{
  position:fixed;
  inset:0;
  z-index:9999;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:16px;
  background: radial-gradient(900px 500px at 20% 10%, rgba(28,37,96,.75), rgba(11,16,32,.92) 55%),
              radial-gradient(900px 600px at 90% 90%, rgba(42,16,64,.75), rgba(11,16,32,.92) 60%);
  backdrop-filter: blur(6px);
}

.startCard{
  width:min(920px, 100%);
  border-radius:18px;
  border:1px solid rgba(255,255,255,.12);
  background:rgba(18,25,57,0.88);
  box-shadow:0 18px 44px rgba(0,0,0,.55);
  overflow:hidden;
  display:grid;
  grid-template-columns: 1fr 1fr;
}
@media (max-width: 860px){
  .startCard{ grid-template-columns:1fr; }
}

.startLeft{
  padding:18px;
  display:flex;
  flex-direction:column;
  gap:12px;
}
.startTitle{
  font-weight:900;
  font-size:clamp(20px, 2.4vw, 26px);
}
.startSubtitle{
  color:var(--muted);
  font-size:14px;
  line-height:1.35;
}

.startForm{
  margin-top:6px;
  display:flex;
  flex-direction:column;
  gap:10px;
}
.startForm label{
  font-weight:800;
  color:#dbe7ff;
  font-size:13px;
}
.startForm input{
  width:100%;
  padding:12px 12px;
  border-radius:12px;
  border:1px solid rgba(255,255,255,.14);
  background:#0f1533;
  color:var(--ink);
  font-weight:800;
  outline:none;
}
.startForm input:focus{
  border-color: rgba(0,225,255,.7);
  box-shadow: 0 0 0 3px rgba(0,225,255,.15);
}

.startActions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin-top:6px;
}
.btnPrimary{
  appearance:none;
  border:none;
  cursor:pointer;
  font-weight:900;
  padding:12px 14px;
  border-radius:12px;
  color:#081018;
  background: linear-gradient(90deg, var(--accent), var(--accent-2));
  box-shadow: 0 12px 26px rgba(0,0,0,.35);
}
.btnPrimary:hover{ filter:brightness(1.03); transform:translateY(-1px); }
.btnGhost{
  appearance:none;
  cursor:pointer;
  font-weight:900;
  padding:12px 14px;
  border-radius:12px;
  color:var(--ink);
  border:1px solid rgba(255,255,255,.14);
  background:#0f1533;
}
.btnGhost:hover{ filter:brightness(1.04); transform:translateY(-1px); }

.startRight{
  background:#0f1533;
  border-left:1px solid rgba(255,255,255,.10);
  display:flex;
  align-items:center;
  justify-content:center;
  padding:14px;
}
@media (max-width: 860px){
  .startRight{ border-left:none; border-top:1px solid rgba(255,255,255,.10); }
}
.startPreview{
  width:100%;
  height: clamp(220px, 45vh, 420px);
  border-radius:14px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.12);
  background:#0b1020;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:16px;
  text-align:center;
  color:#b3c2ff;
  font-weight:900;
  line-height:1.35;
}

/* ===== Footer ===== */
footer{opacity:.9; font-size:12px; color:var(--muted); text-align:center}

/* ===== Acessibilidade (foco visível) ===== */
.lifelines button:focus-visible,
.answers button:focus-visible,
#restart:focus-visible,
.btnPrimary:focus-visible,
.btnGhost:focus-visible,
.startForm input:focus-visible{
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* ===== Redução de movimento ===== */
@media (prefers-reduced-motion: reduce){
  *{ transition:none !important; animation:none !important; }
}
</style>
</head>

<body>

<!-- TELA INICIAL -->
<div class="startScreen" id="startScreen" role="dialog" aria-modal="true" aria-label="Tela inicial">
  <div class="startCard">
    <div class="startLeft">
      <div class="startTitle">O Show do Milhão - O Solo</div>
      <div class="startSubtitle">
        Digite seu nome para começar. Você terá 30 segundos por pergunta e pode usar 3 ajudas.
      </div>

      <form class="startForm" id="startForm">
        <label for="playerName">Nome do participante</label>
        <input id="playerName" name="playerName" type="text" maxlength="24"
               placeholder="Ex.: Ana, João, Turma 201..." autocomplete="off" required />
        <div class="startActions">
          <button class="btnPrimary" type="submit">Começar</button>
          <button class="btnGhost" type="button" id="startNoName">Entrar sem nome</button>
        </div>
      </form>
    </div>

    <div class="startRight" aria-hidden="false">
      <div class="startPreview">
        Banco com 100 questões sobre SOLO (pedogênese, intemperismo, textura, CTC, matéria orgânica).
      </div>
    </div>
  </div>
</div>

<div class="app" id="app">
  <header class="card" role="banner">
    <div class="logo"><span class="medal">S</span>O Show do Milhão - O Solo</div>
    <div class="sub">Responda 15 questões. Ordem das perguntas e alternativas muda a cada partida.</div>
  </header>

  <div class="scoreboard" role="status" aria-live="polite">
    <span class="playerTag" id="playerTag" style="display:none;">Jogador: <span id="playerNameTag"></span></span>
    <span>Prêmio atual:</span>
    <span id="payout">0 milhos</span>
    <button id="restart" type="button">Recomeçar</button>
  </div>

  <main class="layout" role="main">
    <section class="play card" aria-live="polite">
      <div class="status">
        <div class="lifelines">
          <button id="fifty" aria-disabled="false">Eliminar metade</button>
          <button id="skip" aria-disabled="false">Pular</button>
          <button id="ask" aria-disabled="false">Pergunte ao especialista</button>
        </div>
        <div class="meta"><span id="qpos">Pergunta 1/15</span></div>
      </div>

      <div class="timer" aria-label="Tempo restante">
        <div class="fill" id="tfill"></div>
        <div class="clock" id="tclock">30s</div>
      </div>

      <div id="question" class="question" role="heading" aria-level="2">Aguardando início…</div>
      <div id="qmeta" class="meta" aria-hidden="false"></div>
      <div id="answers" class="answers" role="group" aria-label="Alternativas de resposta"></div>
    </section>

    <aside class="host card" aria-label="Painel lateral">
      <div class="hostFrame">
        <div class="placeholder">
          Dica: use o PDF "O Solo" como material de estudo.
        </div>
      </div>
      <div class="hostCaption">O Solo</div>
    </aside>
  </main>

  <footer>Professor Fernando Hax.</footer>
</div>

<script>
/* =========================
   Utilitários
========================= */
const shuffle = arr => arr.map(v=>[Math.random(),v]).sort((a,b)=>a[0]-b[0]).map(v=>v[1]);
const fmtMilhos = n => `${n.toLocaleString('pt-BR')} milhos`;

function escapeHTML(str){
  return String(str)
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#039;");
}

/* =========================
   Regras do jogo
========================= */
const PRIZES = [1000, 2000, 5000, 10000, 20000, 30000, 50000, 100000, 200000, 300000, 400000, 500000, 600000, 800000, 1000000];
const SAFE_STOPS = [5,10];
const TOTAL_Q = 15;

const TIME_PER_Q = 30_000;
let tStart = 0, tRemain = TIME_PER_Q, tTick = null, isTiming = false;

let state;
let playerName = "";

/* =========================
   Banco de 100 questões (base: PDF "O Solo")
   Formato:
   { id, q, options:[...4], a: índice correto (0..3), meta }
========================= */
const QBANK = [
  {id:1,  q:"O solo é definido principalmente como:", options:[
    "Um meio complexo e heterogêneo com minerais, matéria orgânica, água, ar e organismos vivos",
    "Apenas rocha moída misturada com água",
    "Um material homogêneo, sem vida, usado apenas na construção civil",
    "Um reservatório de fertilizantes químicos prontos"
  ], a:0, meta:"Conceito de solo"},
  {id:2,  q:"Qual alternativa é uma função do solo?", options:[
    "Manutenção do ciclo da água e dos nutrientes",
    "Produção de energia elétrica por si só",
    "Substituição do clima local",
    "Eliminação total de organismos vivos"
  ], a:0, meta:"Funções do solo"},
  {id:3,  q:"Pedogênese é:", options:[
    "O processo de formação e desenvolvimento dos solos",
    "A queima controlada do solo para aumentar a fertilidade",
    "O processo de compactar o solo para reduzir erosão",
    "A irrigação artificial de um terreno"
  ], a:0, meta:"Pedogênese"},
  {id:4, q:"A expressão clássica da formação do solo pode ser representada por:", options:[
    "Solo = Rocha + Clima + Tempo + Relevo + Organismos",
    "Solo = Água + Fertilizante + Trator",
    "Solo = Semente + Luz + CO2",
    "Solo = Areia + Argila apenas"
  ], a:0, meta:"Fatores de formação"},
  {id:5, q:"Quanto tempo (aprox.) pode levar para formar 1 cm de solo?", options:[
    "Cerca de 400 anos",
    "Cerca de 40 anos",
    "Cerca de 4 anos",
    "Cerca de 4 meses"
  ], a:0, meta:"Tempo de formação"},
  {id:6, q:"Intemperismo é o processo pelo qual:", options:[
    "Rochas e minerais são alterados pela ação do tempo e do meio ambiente",
    "A matéria orgânica vira húmus exclusivamente por minhocas",
    "A água do lençol freático evapora e vira chuva",
    "Os nutrientes são aplicados em cobertura e incorporados"
  ], a:0, meta:"Intemperismo"},
  {id:7, q:"Existem dois tipos principais de intemperismo:", options:[
    "Físico e químico",
    "Biológico e térmico",
    "Químico e elétrico",
    "Físico e magnético"
  ], a:0, meta:"Intemperismo"},
  {id:8, q:"O intemperismo físico é associado a:", options:[
    "Mudanças mecânicas (quebra, fissuração, abrasão) nas rochas",
    "Dissolução química por CO2 em rocha calcária",
    "Formação de húmus por humificação",
    "Fixação biológica de nitrogênio"
  ], a:0, meta:"Intemperismo físico"},
  {id:9, q:"O intemperismo químico envolve:", options:[
    "Dissolução ou alteração química de minerais e rochas",
    "Somente a quebra mecânica por variação de temperatura",
    "Apenas a ação de vento forte",
    "A compactação do solo por máquinas"
  ], a:0, meta:"Intemperismo químico"},
  {id:10, q:"A rocha original da qual o solo se forma é chamada de:", options:[
    "Rocha-mãe (rocha matriz)",
    "Húmus",
    "Silte",
    "Lençol freático"
  ], a:0, meta:"Rocha-mãe"},
  {id:11, q:"Rochas-mães ricas em quartzo tendem a formar solos:", options:[
    "Menos férteis",
    "Mais férteis",
    "Sempre orgânicos",
    "Sempre alcalinos"
  ], a:0, meta:"Composição mineralógica"},
  {id:12, q:"Alta porosidade/permeabilidade na rocha-mãe favorece:", options:[
    "Entrada de água e gases, importante para crescimento de plantas",
    "Formação de solo sem água disponível",
    "Eliminação de toda a fase gasosa do solo",
    "Redução total de raízes e microrganismos"
  ], a:0, meta:"Porosidade e permeabilidade"},
  {id:13, q:"No clima, um fator que afeta a formação do solo é:", options:[
    "Precipitação",
    "Cor da planta cultivada",
    "Tipo de combustível usado no trator",
    "Marca do calcário"
  ], a:0, meta:"Clima"},
  {id:14, q:"Segundo o material, a temperatura influencia sobretudo:", options:[
    "A taxa de intemperismo físico e químico",
    "A cor do lençol freático",
    "A existência de quartzo no solo",
    "A textura como areia/silte/argila diretamente"
  ], a:0, meta:"Clima"},
  {id:15, q:"O tempo é importante na formação do solo porque:", options:[
    "Controla a velocidade e extensão do intemperismo e da erosão",
    "Substitui o papel da rocha-mãe",
    "Elimina o efeito do relevo",
    "Impede a ação dos organismos"
  ], a:0, meta:"Tempo"},
  {id:16, q:"Organismos do solo contribuem para:", options:[
    "Decomposição de matéria orgânica e liberação de nutrientes",
    "Aumento da salinidade por definição",
    "Neutralização completa do pH em todos os solos",
    "Transformar argila em areia"
  ], a:0, meta:"Organismos"},
  {id:17, q:"Um exemplo citado de efeito biológico no solo é:", options:[
    "Fixação de nitrogênio por bactérias",
    "Produção de rocha calcária por fungos",
    "Transformação de água em potássio",
    "Criação de minerais primários novos por minhocas"
  ], a:0, meta:"Organismos"},
  {id:18, q:"No solo como sistema trifásico, as fases são:", options:[
    "Sólida, líquida e gasosa",
    "Sólida, elétrica e magnética",
    "Orgânica, mineral e metálica",
    "Ácida, básica e neutra"
  ], a:0, meta:"Sistema trifásico"},
  {id:19, q:"A parte sólida do solo é formada principalmente por:", options:[
    "Minerais e matéria orgânica",
    "Apenas água e ar",
    "Somente argila",
    "Somente areia"
  ], a:0, meta:"Composição do solo"},
  {id:20, q:"Os poros do solo são formados principalmente pela:", options:[
